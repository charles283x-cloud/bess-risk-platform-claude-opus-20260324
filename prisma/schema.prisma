generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @db.VarChar(200)
  location          String   @db.VarChar(300)
  capacityMw        Decimal? @map("capacity_mw") @db.Decimal(10, 2)
  capacityMwh       Decimal? @map("capacity_mwh") @db.Decimal(10, 2)
  phase             String   @db.VarChar(20)
  targetSigningDate DateTime? @map("target_signing_date") @db.Date
  targetStartDate   DateTime? @map("target_start_date") @db.Date
  targetEndDate     DateTime? @map("target_end_date") @db.Date
  notes             String?
  isHighRisk        Boolean  @default(false) @map("is_high_risk")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  checklistItems  ChecklistItem[]
  milestones      Milestone[]
  changeRequests  ChangeRequest[]
  payments        PaymentRecord[]
  contracts       Contract[]
  documents       ProjectDocument[]
  photos          SitePhoto[]

  @@map("projects")
}

model ChecklistItem {
  id              String    @id @default(uuid()) @db.Uuid
  projectId       String    @map("project_id") @db.Uuid
  templateId      String?   @map("template_id") @db.Uuid
  name            String    @db.VarChar(300)
  category        String    @db.VarChar(20)
  phase           String    @db.VarChar(20)
  riskDescription String    @map("risk_description")
  assignee        String?   @db.VarChar(100)
  deadline        DateTime? @db.Date
  isComplete      Boolean   @default(false) @map("is_complete")
  completedAt     DateTime? @map("completed_at") @db.Timestamptz()
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template    ChecklistTemplate? @relation(fields: [templateId], references: [id])
  attachments Attachment[]

  @@index([projectId])
  @@map("checklist_items")
}

model Attachment {
  id              String   @id @default(uuid()) @db.Uuid
  checklistItemId String   @map("checklist_item_id") @db.Uuid
  originalName    String   @map("original_name") @db.VarChar(500)
  storedName      String   @map("stored_name") @db.VarChar(500)
  mimeType        String   @map("mime_type") @db.VarChar(100)
  sizeBytes       Int      @map("size_bytes")
  uploadedAt      DateTime @default(now()) @map("uploaded_at") @db.Timestamptz()

  checklistItem ChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@index([checklistItemId])
  @@map("attachments")
}

model ChecklistTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(300)
  category        String   @db.VarChar(20)
  phase           String   @db.VarChar(20)
  riskDescription String   @map("risk_description")
  defaultDays     Int      @default(30) @map("default_days")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  checklistItems ChecklistItem[]

  @@unique([name, phase])
  @@map("checklist_templates")
}

model Milestone {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  name             String    @db.VarChar(300)
  description      String?
  isHardGate       Boolean   @default(false) @map("is_hard_gate")
  plannedStartDate DateTime? @map("planned_start_date") @db.Date
  plannedEndDate   DateTime? @map("planned_end_date") @db.Date
  actualStartDate  DateTime? @map("actual_start_date") @db.Date
  actualEndDate    DateTime? @map("actual_end_date") @db.Date
  status           String    @default("not_started") @db.VarChar(20)
  notes       String?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("milestones")
}

model ChangeRequest {
  id             String    @id @default(uuid()) @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  title          String    @db.VarChar(300)
  description    String
  impactType     String    @map("impact_type") @db.VarChar(20)
  impactDays     Int?      @map("impact_days")
  impactCost     Decimal?  @map("impact_cost") @db.Decimal(12, 0)
  impactDetail   String    @map("impact_detail")
  options        Json
  decisionStatus String    @default("pending") @map("decision_status") @db.VarChar(20)
  decisionDate   DateTime? @map("decision_date") @db.Date
  decisionNotes  String?   @map("decision_notes")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("change_requests")
}

model PaymentRecord {
  id             String    @id @default(uuid()) @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  type           String    @db.VarChar(20) // income | expense
  category       String    @db.VarChar(50)
  description    String    @db.VarChar(500)
  plannedAmount  Decimal   @map("planned_amount") @db.Decimal(14, 2)
  plannedDate    DateTime  @map("planned_date") @db.Date
  actualAmount   Decimal?  @map("actual_amount") @db.Decimal(14, 2)
  actualDate     DateTime? @map("actual_date") @db.Date
  notes          String?
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("payment_records")
}

model Contract {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  category     String   @default("incoming") @db.VarChar(20) // incoming | subcontract
  name         String   @db.VarChar(300)
  originalName String   @map("original_name") @db.VarChar(500)
  storedName   String   @map("stored_name") @db.VarChar(500)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  sizeBytes    Int      @map("size_bytes")
  uploadedAt   DateTime @default(now()) @map("uploaded_at") @db.Timestamptz()

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("contracts")
}

model ProjectDocument {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  category     String   @db.VarChar(30)
  name         String   @db.VarChar(300)
  originalName String   @map("original_name") @db.VarChar(500)
  storedName   String   @map("stored_name") @db.VarChar(500)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  sizeBytes    Int      @map("size_bytes")
  uploadedAt   DateTime @default(now()) @map("uploaded_at") @db.Timestamptz()

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_documents")
}

model SitePhoto {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  description  String?  @db.VarChar(500)
  originalName String   @map("original_name") @db.VarChar(500)
  storedName   String   @map("stored_name") @db.VarChar(500)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  sizeBytes    Int      @map("size_bytes")
  takenAt      DateTime? @map("taken_at") @db.Timestamptz()
  uploadedAt   DateTime @default(now()) @map("uploaded_at") @db.Timestamptz()

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("site_photos")
}
